# ── Database ──────────────────────────────────────────────────
# A single DATABASE_URL works everywhere — local Docker Postgres, Supabase,
# or Railway's injected Postgres URL. Any scheme (postgres://, postgresql://,
# postgresql+asyncpg://) is normalized automatically (see app/core/config.py).
#
# Local (docker-compose):
DATABASE_URL=postgresql+asyncpg://scribe:scribe@localhost:5432/thescribe
#
# Railway example (Railway injects this automatically when you add a Postgres
# service and reference it as ${{Postgres.DATABASE_URL}} in your service vars):
# DATABASE_URL=postgresql://postgres:password@containers-us-west-1.railway.app:5432/railway
#
# Supabase example:
# DATABASE_URL=postgresql://postgres:password@db.xxxxxxxx.supabase.co:5432/postgres

# ── Supabase (optional — only needed if using Supabase Storage/Auth directly) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# ── LLM Provider ─────────────────────────────────────────────
# "anthropic" = production quality (Claude Sonnet 4) — recommended for the
#                final demo and any output you'll submit.
# "groq"      = free tier, very fast, good for development iteration and
#                live walkthroughs without burning Anthropic credits.
# Swap providers without touching any code — just change this value and restart.
LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

GROQ_API_KEY=gsk_your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ── JWT ───────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Redis (for Dramatiq background jobs) ────────────────────
# Local (docker-compose):
REDIS_URL=redis://localhost:6379/0
# Railway: reference ${{Redis.REDIS_URL}} after adding the Redis plugin.

# ── Embeddings ────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── App ───────────────────────────────────────────────────────
# "development" or "production". In production, validate_for_startup() will
# raise if SECRET_KEY is still the default placeholder.
ENVIRONMENT=development

# JSON array of allowed frontend origins.
CORS_ORIGINS=["http://localhost:5173"]

# Railway injects PORT automatically — only needed locally if you want a
# non-default port for `uvicorn app.main:app --port $PORT`.
PORT=8000
