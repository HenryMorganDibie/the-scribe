# Database
DATABASE_URL=postgresql+asyncpg://scribe:scribe@localhost:5432/thescribe
SYNC_DATABASE_URL=postgresql://scribe:scribe@localhost:5432/thescribe

# Supabase (optional — only needed if using Supabase for auth/storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# ── LLM Provider ─────────────────────────────────────────────
# "anthropic" = production quality (Claude Sonnet 4) — recommended for the
#                final demo and any output you'll submit.
# "groq"      = free tier, very fast, good for development iteration and
#                live walkthroughs without burning Anthropic credits.
# Swap providers without touching any code — just change this value and restart.
LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

GROQ_API_KEY=gsk_your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# JWT
SECRET_KEY=change-this-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Redis (for Dramatiq background jobs)
REDIS_URL=redis://localhost:6379/0

# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# App
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:5173","https://thescribe.app"]
